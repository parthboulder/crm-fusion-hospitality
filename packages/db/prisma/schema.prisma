generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Organizations ─────────────────────────────────────────────────────────────

model Organization {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  slug       String   @unique
  plan       String   @default("enterprise")
  settings   Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  properties    Property[]
  roles         Role[]
  userProfiles  UserProfile[]
  reports       Report[]
  alerts        Alert[]
  tasks         Task[]
  aiSummaries   AiSummary[]

  @@map("organizations")
}

// ─── Properties ────────────────────────────────────────────────────────────────

model Property {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  name        String
  brand       String?
  brandCode   String?  @map("brand_code")
  address     String?
  city        String?
  state       String?
  country     String   @default("US")
  timezone    String   @default("America/New_York")
  totalRooms  Int?     @map("total_rooms")
  pmsType     String?  @map("pms_type")
  adrFloor    Decimal? @map("adr_floor") @db.Decimal(12, 2)
  isActive    Boolean  @default(true) @map("is_active")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organization        Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  reports             Report[]
  dailyMetrics        DailyMetrics[]
  financialMetrics    FinancialMetrics[]
  alerts              Alert[]
  tasks               Task[]
  userPropertyAccess  UserPropertyAccess[]

  @@index([orgId])
  @@index([brand])
  @@map("properties")
}

// ─── RBAC ──────────────────────────────────────────────────────────────────────

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  name        String
  displayName String   @map("display_name")
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")

  organization    Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userProfiles    UserProfile[]
  rolePermissions RolePermission[]

  @@unique([orgId, name])
  @@map("roles")
}

model Permission {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resource    String
  action      String
  description String?

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserProfile {
  id          String    @id @db.Uuid
  orgId       String    @map("org_id") @db.Uuid
  fullName    String    @map("full_name")
  email       String
  phone       String?
  avatarUrl   String?   @map("avatar_url")
  roleId      String    @map("role_id") @db.Uuid
  isActive    Boolean   @default(true) @map("is_active")
  mfaEnabled  Boolean   @default(false) @map("mfa_enabled")
  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  organization        Organization         @relation(fields: [orgId], references: [id])
  role                Role                 @relation(fields: [roleId], references: [id])
  userPropertyAccess  UserPropertyAccess[]
  uploadedReports     Report[]             @relation("UploadedBy")
  reviewedReports     Report[]             @relation("ReviewedBy")
  acknowledgedAlerts  Alert[]              @relation("AcknowledgedBy")
  resolvedAlerts      Alert[]              @relation("ResolvedBy")
  assignedTasks       Task[]               @relation("AssignedTo")
  assignerTasks       Task[]               @relation("AssignedBy")
  taskComments        TaskComment[]
  sessions            UserSession[]
  metricOverrides     MetricOverride[]     @relation("CreatedBy")
  approvedOverrides   MetricOverride[]     @relation("ApprovedBy")

  @@index([orgId])
  @@index([roleId])
  @@map("user_profiles")
}

model UserPropertyAccess {
  userId      String   @map("user_id") @db.Uuid
  propertyId  String   @map("property_id") @db.Uuid
  grantedBy   String   @map("granted_by") @db.Uuid
  grantedAt   DateTime @default(now()) @map("granted_at")

  user     UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@id([userId, propertyId])
  @@map("user_property_access")
}

// ─── Sessions ──────────────────────────────────────────────────────────────────

model UserSession {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String    @map("user_id") @db.Uuid
  tokenHash           String    @map("token_hash")
  ipAddress           String?   @map("ip_address")
  userAgent           String?   @map("user_agent")
  deviceFingerprint   String?   @map("device_fingerprint")
  isActive            Boolean   @default(true) @map("is_active")
  lastActivity        DateTime  @default(now()) @map("last_activity")
  expiresAt           DateTime  @map("expires_at")
  revokedAt           DateTime? @map("revoked_at")
  revokedBy           String?   @map("revoked_by") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at")

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([tokenHash])
  @@map("user_sessions")
}

// ─── Reports ───────────────────────────────────────────────────────────────────

model Report {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId            String    @map("org_id") @db.Uuid
  propertyId       String    @map("property_id") @db.Uuid
  reportType       String    @map("report_type")
  reportDate       DateTime  @map("report_date") @db.Date
  reportingPeriod  String?   @map("reporting_period")
  source           String
  status           String    @default("pending")
  confidenceScore  Decimal?  @map("confidence_score") @db.Decimal(5, 4)
  requiresReview   Boolean   @default(false) @map("requires_review")
  reviewedBy       String?   @map("reviewed_by") @db.Uuid
  reviewedAt       DateTime? @map("reviewed_at")
  reviewNotes      String?   @map("review_notes")
  uploadedBy       String?   @map("uploaded_by") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  organization    Organization    @relation(fields: [orgId], references: [id])
  property        Property        @relation(fields: [propertyId], references: [id])
  uploader        UserProfile?    @relation("UploadedBy", fields: [uploadedBy], references: [id])
  reviewer        UserProfile?    @relation("ReviewedBy", fields: [reviewedBy], references: [id])
  files           ReportFile[]
  extractionJobs  ExtractionJob[]
  dailyMetrics    DailyMetrics[]
  financialMetrics FinancialMetrics[]
  alerts          Alert[]

  @@index([propertyId, reportDate(sort: Desc)])
  @@index([reportType])
  @@index([status])
  @@index([orgId])
  @@map("reports")
}

model ReportFile {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reportId         String    @map("report_id") @db.Uuid
  storagePath      String    @map("storage_path")
  originalName     String    @map("original_name")
  mimeType         String    @map("mime_type")
  fileSizeBytes    BigInt    @map("file_size_bytes")
  checksumSha256   String    @map("checksum_sha256")
  virusScanStatus  String    @default("pending") @map("virus_scan_status")
  virusScanAt      DateTime? @map("virus_scan_at")
  version          Int       @default(1)
  isCurrent        Boolean   @default(true) @map("is_current")
  uploadedBy       String?   @map("uploaded_by") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("report_files")
}

model ExtractionJob {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reportId      String    @map("report_id") @db.Uuid
  modelUsed     String    @default("claude-sonnet-4-6") @map("model_used")
  promptVersion String    @map("prompt_version")
  tokensUsed    Int?      @map("tokens_used")
  costUsd       Decimal?  @map("cost_usd") @db.Decimal(10, 6)
  durationMs    Int?      @map("duration_ms")
  status        String    @default("pending")
  errorMessage  String?   @map("error_message")
  rawResponse   Json?     @map("raw_response")
  startedAt     DateTime? @map("started_at")
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  report Report @relation(fields: [reportId], references: [id])

  @@index([reportId])
  @@map("extraction_jobs")
}

// ─── Metrics ───────────────────────────────────────────────────────────────────

model DailyMetrics {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reportId            String    @map("report_id") @db.Uuid
  propertyId          String    @map("property_id") @db.Uuid
  metricDate          DateTime  @map("metric_date") @db.Date
  totalRooms          Int?      @map("total_rooms")
  roomsSold           Int?      @map("rooms_sold")
  roomsOoo            Int?      @map("rooms_ooo")
  roomsComplimentary  Int?      @map("rooms_complimentary")
  occupancyPct        Decimal?  @map("occupancy_pct") @db.Decimal(7, 4)
  adr                 Decimal?  @db.Decimal(12, 2)
  revpar              Decimal?  @db.Decimal(12, 2)
  totalRevenue        Decimal?  @map("total_revenue") @db.Decimal(14, 2)
  roomRevenue         Decimal?  @map("room_revenue") @db.Decimal(14, 2)
  fbRevenue           Decimal?  @map("fb_revenue") @db.Decimal(14, 2)
  otherRevenue        Decimal?  @map("other_revenue") @db.Decimal(14, 2)
  pyTotalRevenue      Decimal?  @map("py_total_revenue") @db.Decimal(14, 2)
  pyRoomRevenue       Decimal?  @map("py_room_revenue") @db.Decimal(14, 2)
  pyOccupancyPct      Decimal?  @map("py_occupancy_pct") @db.Decimal(7, 4)
  pyAdr               Decimal?  @map("py_adr") @db.Decimal(12, 2)
  pyRevpar            Decimal?  @map("py_revpar") @db.Decimal(12, 2)
  budgetOccupancyPct  Decimal?  @map("budget_occupancy_pct") @db.Decimal(7, 4)
  budgetAdr           Decimal?  @map("budget_adr") @db.Decimal(12, 2)
  budgetRevpar        Decimal?  @map("budget_revpar") @db.Decimal(12, 2)
  budgetTotalRevenue  Decimal?  @map("budget_total_revenue") @db.Decimal(14, 2)
  forecastOccupancyPct Decimal? @map("forecast_occupancy_pct") @db.Decimal(7, 4)
  forecastRevenue     Decimal?  @map("forecast_revenue") @db.Decimal(14, 2)
  confidenceScore     Decimal?  @map("confidence_score") @db.Decimal(5, 4)
  extractionNotes     String?   @map("extraction_notes")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  report   Report   @relation(fields: [reportId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, metricDate])
  @@index([reportId])
  @@map("daily_metrics")
}

model FinancialMetrics {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reportId          String    @map("report_id") @db.Uuid
  propertyId        String    @map("property_id") @db.Uuid
  metricDate        DateTime  @map("metric_date") @db.Date
  arCurrent         Decimal?  @map("ar_current") @db.Decimal(14, 2)
  ar30Days          Decimal?  @map("ar_30_days") @db.Decimal(14, 2)
  ar60Days          Decimal?  @map("ar_60_days") @db.Decimal(14, 2)
  ar90Days          Decimal?  @map("ar_90_days") @db.Decimal(14, 2)
  ar90PlusDays      Decimal?  @map("ar_90_plus_days") @db.Decimal(14, 2)
  arTotal           Decimal?  @map("ar_total") @db.Decimal(14, 2)
  ccVisa            Decimal?  @map("cc_visa") @db.Decimal(14, 2)
  ccMastercard      Decimal?  @map("cc_mastercard") @db.Decimal(14, 2)
  ccAmex            Decimal?  @map("cc_amex") @db.Decimal(14, 2)
  ccDiscover        Decimal?  @map("cc_discover") @db.Decimal(14, 2)
  ccOther           Decimal?  @map("cc_other") @db.Decimal(14, 2)
  ccTotal           Decimal?  @map("cc_total") @db.Decimal(14, 2)
  ccDisputes        Decimal?  @map("cc_disputes") @db.Decimal(14, 2)
  cashSales         Decimal?  @map("cash_sales") @db.Decimal(14, 2)
  cashDeposits      Decimal?  @map("cash_deposits") @db.Decimal(14, 2)
  cashVariance      Decimal?  @map("cash_variance") @db.Decimal(14, 2)
  adjustmentsTotal  Decimal?  @map("adjustments_total") @db.Decimal(14, 2)
  voidsTotal        Decimal?  @map("voids_total") @db.Decimal(14, 2)
  compsTotal        Decimal?  @map("comps_total") @db.Decimal(14, 2)
  discountsTotal    Decimal?  @map("discounts_total") @db.Decimal(14, 2)
  taxCollected      Decimal?  @map("tax_collected") @db.Decimal(14, 2)
  taxExemptTotal    Decimal?  @map("tax_exempt_total") @db.Decimal(14, 2)
  guestLedgerBalance Decimal? @map("guest_ledger_balance") @db.Decimal(14, 2)
  advanceDeposits   Decimal?  @map("advance_deposits") @db.Decimal(14, 2)
  confidenceScore   Decimal?  @map("confidence_score") @db.Decimal(5, 4)
  extractionNotes   String?   @map("extraction_notes")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  report   Report   @relation(fields: [reportId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, metricDate])
  @@index([reportId])
  @@map("financial_metrics")
}

model MetricOverride {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tableName        String    @map("table_name")
  recordId         String    @map("record_id") @db.Uuid
  fieldName        String    @map("field_name")
  oldValue         String?   @map("old_value")
  newValue         String    @map("new_value")
  overrideReason   String    @map("override_reason")
  approvedBy       String?   @map("approved_by") @db.Uuid
  approvedAt       DateTime? @map("approved_at")
  requiresApproval Boolean   @default(true) @map("requires_approval")
  createdBy        String    @map("created_by") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")

  creator  UserProfile  @relation("CreatedBy", fields: [createdBy], references: [id])
  approver UserProfile? @relation("ApprovedBy", fields: [approvedBy], references: [id])

  @@map("metric_overrides")
}

// ─── Alerts & Tasks ────────────────────────────────────────────────────────────

model Alert {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId            String    @map("org_id") @db.Uuid
  propertyId       String    @map("property_id") @db.Uuid
  reportId         String?   @map("report_id") @db.Uuid
  alertType        String    @map("alert_type")
  severity         String
  title            String
  description      String
  metricName       String?   @map("metric_name")
  metricValue      Decimal?  @map("metric_value") @db.Decimal(14, 4)
  thresholdValue   Decimal?  @map("threshold_value") @db.Decimal(14, 4)
  priorValue       Decimal?  @map("prior_value") @db.Decimal(14, 4)
  pctChange        Decimal?  @map("pct_change") @db.Decimal(7, 4)
  status           String    @default("open")
  acknowledgedBy   String?   @map("acknowledged_by") @db.Uuid
  acknowledgedAt   DateTime? @map("acknowledged_at")
  resolvedBy       String?   @map("resolved_by") @db.Uuid
  resolvedAt       DateTime? @map("resolved_at")
  resolutionNotes  String?   @map("resolution_notes")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  organization  Organization  @relation(fields: [orgId], references: [id])
  property      Property      @relation(fields: [propertyId], references: [id])
  report        Report?       @relation(fields: [reportId], references: [id])
  acknowledger  UserProfile?  @relation("AcknowledgedBy", fields: [acknowledgedBy], references: [id])
  resolver      UserProfile?  @relation("ResolvedBy", fields: [resolvedBy], references: [id])
  tasks         Task[]

  @@index([propertyId, createdAt(sort: Desc)])
  @@index([severity, status])
  @@index([orgId])
  @@map("alerts")
}

model Task {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String    @map("org_id") @db.Uuid
  propertyId  String    @map("property_id") @db.Uuid
  alertId     String?   @map("alert_id") @db.Uuid
  title       String
  description String?
  taskType    String    @map("task_type")
  priority    String
  status      String    @default("open")
  assignedTo  String?   @map("assigned_to") @db.Uuid
  assignedBy  String?   @map("assigned_by") @db.Uuid
  dueDate     DateTime? @map("due_date") @db.Date
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [orgId], references: [id])
  property     Property      @relation(fields: [propertyId], references: [id])
  alert        Alert?        @relation(fields: [alertId], references: [id])
  assignee     UserProfile?  @relation("AssignedTo", fields: [assignedTo], references: [id])
  assigner     UserProfile?  @relation("AssignedBy", fields: [assignedBy], references: [id])
  comments     TaskComment[]

  @@index([propertyId])
  @@index([assignedTo, status])
  @@map("tasks")
}

model TaskComment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId    String   @map("task_id") @db.Uuid
  authorId  String   @map("author_id") @db.Uuid
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  task   Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author UserProfile @relation(fields: [authorId], references: [id])

  @@index([taskId])
  @@map("task_comments")
}

// ─── AI ────────────────────────────────────────────────────────────────────────

model AiSummary {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  scope        String
  scopeId      String   @map("scope_id") @db.Uuid
  summaryType  String   @map("summary_type")
  content      String
  modelUsed    String   @map("model_used")
  tokensUsed   Int?     @map("tokens_used")
  generatedAt  DateTime @default(now()) @map("generated_at")
  validUntil   DateTime? @map("valid_until")
  metadata     Json     @default("{}")

  organization Organization @relation(fields: [orgId], references: [id])

  @@index([scope, scopeId, generatedAt(sort: Desc)])
  @@map("ai_summaries")
}

// ─── Audit Logs ────────────────────────────────────────────────────────────────

model AuditLog {
  id            BigInt   @id @default(autoincrement())
  orgId         String?  @map("org_id") @db.Uuid
  userId        String?  @map("user_id") @db.Uuid
  sessionId     String?  @map("session_id")
  action        String
  resourceType  String   @map("resource_type")
  resourceId    String?  @map("resource_id")
  beforeValue   Json?    @map("before_value")
  afterValue    Json?    @map("after_value")
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  requestId     String?  @map("request_id")
  result        String   @default("success")
  failureReason String?  @map("failure_reason")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt(sort: Desc)])
  @@index([resourceType, resourceId])
  @@index([orgId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@map("audit_logs")
}
