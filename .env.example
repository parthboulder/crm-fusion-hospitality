# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:your-password@db.your-project.supabase.co:6543/postgres

# ─── API ──────────────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=change-this-to-a-long-random-secret-min-32-chars
CORS_ORIGIN=http://localhost:5173

# ─── Claude AI ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ─── File Storage ─────────────────────────────────────────────────────────────
STORAGE_BUCKET_REPORTS=reports-private
SIGNED_URL_EXPIRY_SECONDS=900

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=alerts@fusion-hospitality.com

# ─── Dropbox Integration ──────────────────────────────────────────────────────
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_WEBHOOK_SECRET=

# ─── OneDrive Integration ─────────────────────────────────────────────────────
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_TENANT_ID=
ONEDRIVE_WEBHOOK_SECRET=

# ─── Security ─────────────────────────────────────────────────────────────────
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_API_MAX=300
SESSION_MAX_CONCURRENT=5
MFA_REQUIRED_ROLES=super_admin,finance,corporate
