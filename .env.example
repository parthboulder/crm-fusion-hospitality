# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Prisma / Postgres ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.your-project.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:YOUR_PASSWORD@db.your-project.supabase.co:5432/postgres

# ─── Auth ─────────────────────────────────────────────────────────────────────
# REQUIRED — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=

# ─── Vite (browser-exposed) ──────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_MOCK=false

# ─── NVIDIA OCR (optional — leave empty to use Tesseract.js fallback) ────────
NVIDIA_API_KEY=

# ─── Email (optional) ────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=alerts@fusion-hospitality.com

# ─── Cloud integrations (optional) ───────────────────────────────────────────
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_WEBHOOK_SECRET=
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_TENANT_ID=
ONEDRIVE_WEBHOOK_SECRET=
