# ─── Scalahosting / Passenger / Apache config for Fusion Hospitality ─────────
#
# Routes:
#   /api/*     → Node app (Passenger)  — everything the API serves
#   /health    → Node app (Passenger)
#   /          → React SPA (static index.html from this public_html dir)
#
# The Node app itself lives OUTSIDE public_html (at ~/apps/fusion/). This
# file only tells Apache to (a) let Passenger handle /api requests and (b)
# serve the built Vite bundle for everything else, with SPA fallback to
# index.html so client-side routing works.

# ─── Passenger ───────────────────────────────────────────────────────────────
# Most Scalahosting setups auto-generate these lines in their Node.js App
# Manager — if yours does, leave this block commented out and use the
# manager UI. Otherwise uncomment and set the paths explicitly.
#
# PassengerNodejs /home/YOURUSER/nodevenv/apps/fusion/20/bin/node
# PassengerAppRoot /home/YOURUSER/apps/fusion
# PassengerAppType node
# PassengerStartupFile app.js
# PassengerAppEnv production

# ─── CORS / security headers ────────────────────────────────────────────────
<IfModule mod_headers.c>
  # Frame busting + MIME sniff prevention
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  # Don't cache index.html — it references hashed asset paths that change
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-store, must-revalidate"
  </FilesMatch>
  # Cache hashed assets aggressively — they're immutable
  <FilesMatch "\.(js|css|woff2?|png|jpg|jpeg|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# ─── Upload size — matches OCR_MAX_FILE_SIZE_BYTES in the API (20 MB) ───────
# Apache default is 1 MB which would silently truncate larger uploads.
# Extra 5 MB headroom for multipart overhead.
LimitRequestBody 26214400

# ─── Rewrite rules ──────────────────────────────────────────────────────────
RewriteEngine On

# Health check passes through to Node
RewriteRule ^health$ - [L]

# API routes pass through to Node (Passenger handles them)
RewriteRule ^api/ - [L]

# Everything else: serve file if it exists, otherwise index.html (SPA fallback)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]

# ─── Compression ────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>
