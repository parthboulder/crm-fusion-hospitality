{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Bash(python:*)",
      "Bash(pip:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git stash:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(modal:*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(credentials.json)",
      "Read(token.json)",
      "Read(service-account*.json)",
      "Read(*secret*)",
      "Read(*.pem)",
      "Read(*.key)",
      "Read(*.p12)",
      "Read(*.pfx)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(credentials.json)",
      "Write(token.json)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(nc:*)",
      "Bash(cat .env*)",
      "Bash(cat credentials.json)",
      "Bash(cat token.json)",
      "Bash(echo $*TOKEN*)",
      "Bash(echo $*SECRET*)",
      "Bash(echo $*KEY*)",
      "Bash(echo $*PASSWORD*)"
    ]
  },
  "defaultMode": "ask",
  "autoMemoryEnabled": true
}
