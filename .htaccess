# ─── Scalahosting / Passenger / Apache config for Fusion Hospitality ─────────
#
# Routes:
#   /api/*     → Node app (Passenger)  — everything the API serves
#   /health    → Node app (Passenger)
#   /          → React SPA (static index.html from this public_html dir)
#
# The Node app itself lives OUTSIDE public_html (at ~/apps/fusion/). This
# file only tells Apache to (a) let Passenger handle /api requests and (b)
# serve the built Vite bundle for everything else, with SPA fallback to
# index.html so client-side routing works.

# ─── Passenger ───────────────────────────────────────────────────────────────
# Most Scalahosting setups auto-generate these lines in their Node.js App
# Manager — if yours does, leave this block commented out and use the
# manager UI. Otherwise uncomment and set the paths explicitly.
#
# PassengerNodejs /home/YOURUSER/nodevenv/apps/fusion/20/bin/node
# PassengerAppRoot /home/YOURUSER/apps/fusion
# PassengerAppType node
# PassengerStartupFile app.js
# PassengerAppEnv production

# ─── Security Headers ──────────────────────────────────────────────────────
<IfModule mod_headers.c>
  # Prevent clickjacking — deny all framing (matches Fastify's frame-ancestors 'none')
  Header always set X-Frame-Options "DENY"

  # Prevent MIME-type sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Referrer policy — send origin only on cross-origin requests
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Enforce HTTPS via HSTS (1 year, include subdomains)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Block XSS in legacy browsers that don't support CSP
  Header always set X-XSS-Protection "1; mode=block"

  # Prevent the site from being used as a cross-origin opener
  Header always set Cross-Origin-Opener-Policy "same-origin"

  # Restrict what resources the browser can load (matches Fastify CSP in production)
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' https://rsms.me; img-src 'self' data: blob:; connect-src 'self' https://cqnbtcbiwhdmqbitxhsk.supabase.co; font-src 'self' https://rsms.me; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"

  # Prevent cross-origin reads of responses
  Header always set Cross-Origin-Resource-Policy "same-origin"

  # Block access to the site's features from cross-origin iframes
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"

  # ─── Cache Strategy ──────────────────────────────────────────────────────
  # index.html must never be cached — it references hashed asset paths that change
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-store, no-cache, must-revalidate"
    Header set Pragma "no-cache"
  </FilesMatch>

  # Hashed assets (Vite produces filenames like main-abc123.js) are immutable
  <FilesMatch "\.(js|css|woff2?|png|jpg|jpeg|webp|svg|ico|avif)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # JSON/API data should not be cached by proxies
  <FilesMatch "\.(json)$">
    Header set Cache-Control "no-store"
  </FilesMatch>

  # ─── Strip Server Info ──────────────────────────────────────────────────
  # Remove Apache version and OS from response headers
  Header always unset X-Powered-By
  Header always unset Server
</IfModule>

# ─── Disable Server Signature & Version ─────────────────────────────────────
ServerSignature Off

# ─── Upload Size ────────────────────────────────────────────────────────────
# Matches the 50 MB multipart limit in Fastify (reduced from 500 MB).
# Extra overhead for multipart encoding.
LimitRequestBody 52428800

# ─── Block Sensitive Files ──────────────────────────────────────────────────
# Prevent direct access to dotfiles, config, source maps, and env files
<FilesMatch "^\.|\.env$|\.map$|\.ts$|\.tsx$|\.log$|\.yml$|\.yaml$|\.toml$|\.lock$|\.md$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>

# Block access to common sensitive paths
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Block .git directory access
  RewriteRule ^\.git - [F,L]

  # Block node_modules
  RewriteRule ^node_modules - [F,L]

  # Block source directories
  RewriteRule ^apps/ - [F,L]
  RewriteRule ^packages/ - [F,L]
  RewriteRule ^supabase/ - [F,L]

  # Block config and build files at root
  RewriteRule ^(tsconfig|package|pnpm|CLAUDE|AGENTS)\..*$ - [F,L]
</IfModule>

# ─── Disable Directory Listing ──────────────────────────────────────────────
Options -Indexes -MultiViews

# ─── Disable TRACE/TRACK Methods ───────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteCond %{REQUEST_METHOD} ^(TRACE|TRACK)
  RewriteRule .* - [F,L]
</IfModule>

# ─── Rewrite Rules — SPA + API Routing ──────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS in production
  RewriteCond %{HTTPS} off
  RewriteCond %{HTTP_HOST} !^localhost
  RewriteCond %{HTTP_HOST} !^127\.0\.0\.1
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Health check passes through to Node (Passenger)
  RewriteRule ^health$ - [L]

  # API routes pass through to Node (Passenger)
  RewriteRule ^api/ - [L]

  # Everything else: serve file if it exists, otherwise index.html (SPA fallback)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]
</IfModule>

# ─── Compression ────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE font/woff2
</IfModule>

# ─── MIME Types ─────────────────────────────────────────────────────────────
<IfModule mod_mime.c>
  AddType application/javascript .js .mjs
  AddType text/css .css
  AddType image/svg+xml .svg .svgz
  AddType image/avif .avif
  AddType image/webp .webp
  AddType font/woff2 .woff2
  AddType application/manifest+json .webmanifest
</IfModule>

# ─── ETag Configuration ────────────────────────────────────────────────────
# Disable ETag (hashed filenames handle cache busting; ETag adds overhead)
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>
FileETag None
